{
  "name": "mind-mapper-desktop",
  "version": "0.1.0",
  "description": "Mind-Mapper desktop app — Windows / macOS / Linux",
  "author": {
    "name": "Mind-Mapper",
    "email": "hello@mind-mapper.com"
  },
  "homepage": "https://mind-mapper.com",
  "license": "UNLICENSED",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "bundle": "cd ../frontend && yarn install --frozen-lockfile && yarn build && cd ../electron && rm -rf assets/web && mkdir -p assets/web && cp -r ../frontend/build/. assets/web/",
    "dist": "yarn bundle && electron-builder",
    "dist:win": "yarn bundle && electron-builder --win",
    "dist:mac": "yarn bundle && electron-builder --mac",
    "dist:linux": "yarn bundle && electron-builder --linux",
    "dist:all": "yarn bundle && electron-builder -mwl",
    "publish": "yarn bundle && electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.mindmapper.desktop",
    "productName": "Mind-Mapper",
    "copyright": "© 2026 Mind-Mapper",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "assets/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "extraMetadata": {
      "version": "0.1.0"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "maximusscotland",
        "repo": "marvex",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "publisherName": "Mind-Mapper"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mind-Mapper"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "dmg": {
      "title": "Mind-Mapper ${version}",
      "backgroundColor": "#04060d"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] },
        { "target": "rpm", "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Office",
      "synopsis": "Turn any PDF into an interactive mind-map",
      "description": "Mind-Mapper — the ultimate research & learning lab. Drop a PDF, watch AI extract every concept into a beautiful interactive mind-map. All local. Zero cloud."
    }
  }
}
